/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "alphazonelabs",
	"main": "src/index.ts",
	"compatibility_date": "2026-01-28",
	"workers_dev": true,
	"observability": { "enabled": true },
	"durable_objects": { "bindings": [{ "name": "SAS_STORE", "class_name": "SasStoreCurrent" }] },
	"migrations": [{ "tag": "v3", "new_sqlite_classes": ["SasStoreCurrent"] }],
	"vars": {
		"FORMS_TO_EMAIL": "info@alphazonelabs.com",
		"FORMS_DISPLAY_TO_EMAIL": "info@alphazonelabs.com",
		"FORMS_FROM_EMAIL": "noreply@alphazonelabs.com",
		"ALLOWED_ORIGINS": "https://alphazonelabs.com,https://www.alphazonelabs.com,https://sas.alphazonelabs.com,http://localhost:5173,http://127.0.0.1:5173,https://hligon35.github.io",
		"SAS_ALLOWED_ORIGINS": "https://alphazonelabs.com,https://www.alphazonelabs.com,https://sas.alphazonelabs.com,http://localhost:5173,http://127.0.0.1:5173",
		"TURNSTILE_SITE_KEY": ""
	},
	"send_email": [
		{
			"name": "EMAIL",
			"destination_address": "info@alphazonelabs.com"
		}
	],
	"env": {
		"sas": {
			"name": "alphazonelabs-sas",
			"workers_dev": false,
			"routes": [
				{
					"pattern": "sas.alphazonelabs.com",
					"custom_domain": true
				}
			],
			"assets": {
				"directory": "../sas/dist",
				"not_found_handling": "single-page-application",
				"run_worker_first": ["/api/*"]
			},
			"send_email": [
				{
					"name": "EMAIL",
					"destination_address": "info@alphazonelabs.com"
				}
			],
			"durable_objects": {
				"bindings": [
					{
						"name": "SAS_STORE",
						"class_name": "SasStoreCurrent"
					}
				]
			},
			"vars": {
				"FORMS_TO_EMAIL": "info@alphazonelabs.com",
				"FORMS_DISPLAY_TO_EMAIL": "info@alphazonelabs.com",
				"FORMS_FROM_EMAIL": "noreply@alphazonelabs.com",
				"ALLOWED_ORIGINS": "https://alphazonelabs.com,https://www.alphazonelabs.com,https://sas.alphazonelabs.com,http://localhost:5173,http://127.0.0.1:5173,https://hligon35.github.io",
				"SAS_ALLOWED_ORIGINS": "https://alphazonelabs.com,https://www.alphazonelabs.com,https://sas.alphazonelabs.com,http://localhost:5173,http://127.0.0.1:5173",
				"TURNSTILE_SITE_KEY": ""
			}
		}
	}
}
